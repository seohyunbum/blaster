{
  "name": "blaster-lab",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build && node scripts/check-bundle-size.mjs",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "node --test tests/*.test.ts",
    "test:browser": "node scripts/browser-smoke.mjs",
    "check:architecture": "node scripts/check-architecture.mjs",
    "check:hotpaths": "node scripts/check-hotpaths.mjs",
    "verify": "npm run typecheck && npm run test && npm run check:architecture && npm run check:hotpaths",
    "verify:full": "npm run verify && npm run build && npm run test:browser"
  },
  "dependencies": {
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "@types/three": "^0.180.0",
    "playwright": "^1.61.1",
    "pngjs": "^7.0.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14"
  }
}
